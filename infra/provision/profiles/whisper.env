# Whisper profile — faster-whisper-server for transcription
# Same GPU caveat as gpu-inference: Hetzner GPU availability is limited.
# Falls back to CPU-mode whisper on a large shared-CPU instance.
PROVIDER=hetzner
SERVER_TYPE=ccx33
LOCATION=fsn1
IMAGE=ubuntu-24.04
SSH_KEY_NAME=sessionhelper
SETUP_SCRIPT=setup/whisper.sh
CACHE_DIRS="docker-images models"
LABELS="project=sessionhelper,role=whisper"
