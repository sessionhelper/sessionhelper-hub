# GPU inference profile — Ollama + qwen2.5:7b
# Hetzner does not currently offer consumer GPU instances.
# This profile is a placeholder for when they do, or for use with
# a provider adapter for RunPod / Vast.ai / Lambda Labs.
# For now: provision a large CPU box and run Ollama in CPU mode,
# or use a dedicated GPU provider manually.
PROVIDER=hetzner
SERVER_TYPE=ccx33
LOCATION=fsn1
IMAGE=ubuntu-24.04
SSH_KEY_NAME=sessionhelper
SETUP_SCRIPT=setup/gpu-ollama.sh
CACHE_DIRS="docker-images models/ollama"
LABELS="project=sessionhelper,role=gpu-inference"
